@page
@{
    var eventId = Request.Query["id"];
}

<h2 class="mb-4">🎟 Book Tickets</h2>

<div class="card p-4 col-md-4 shadow">

    <input type="number" id="seats" class="form-control mb-3" placeholder="Enter seats" min="1" />

    <button onclick="book()" class="btn btn-primary w-100">
        Confirm Booking
    </button>

</div>

@section Scripts {
<script>

// ✅ Extract safely
const eventId = parseInt("@eventId");

// Debug
console.log("Event ID:", eventId);

// ❌ Invalid eventId check
if (!eventId || eventId <= 0) {
    alert("Invalid Event ID");
    window.location.href = "/";
}

// ✅ Auth check
if (!localStorage.getItem("token")) {
    alert("Please login first");
    window.location.href = "/Login";
}

function book() {

    let seats = parseInt(document.getElementById("seats").value);

    if (!seats || seats <= 0) {
        alert("Please enter valid seats");
        return;
    }

    let token = localStorage.getItem("token");

    fetch("http://localhost:5193/api/bookings", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
        },
        body: JSON.stringify({
            eventId: eventId,
            seatsBooked: seats
        })
    })
    .then(res => {
        if (!res.ok) {
            return res.text().then(text => { throw new Error(text); });
        }
        return res.json();
    })
    .then(() => {
        alert("Booking Confirmed ✅");
        window.location.href = "/";
    })
    .catch(err => {
        console.error(err);
        alert("Error: " + err.message);
    });
}

</script>
}