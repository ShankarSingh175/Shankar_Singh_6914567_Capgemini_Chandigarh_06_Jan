@page
@model EventBooking.UI.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<h2 class="text-center mb-4">🔐 Login</h2>

<div class="row justify-content-center">
    <div class="col-md-4">

        <div class="card shadow p-4">

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input id="username" class="form-control" placeholder="Enter username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input id="password" type="password" class="form-control" placeholder="Enter password" />
            </div>

            <button onclick="login()" class="btn btn-dark w-100">
                Login
            </button>

            <p id="errorMsg" class="text-danger mt-3 text-center"></p>

        </div>

    </div>
</div>

@section Scripts {
<script>

// ✅ Redirect if already logged in
if (localStorage.getItem("token")) {
    window.location.href = "/";
}

// ✅ Allow Enter key to login
document.addEventListener("keypress", function (e) {
    if (e.key === "Enter") {
        login();
    }
});

function login() {

    let username = document.getElementById("username").value.trim();
    let password = document.getElementById("password").value.trim();

    // ✅ Validation
    if (!username || !password) {
        document.getElementById("errorMsg").innerText = "All fields are required";
        return;
    }

    fetch("http://localhost:5193/api/auth/login", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            username: username,
            password: password
        })
    })
    .then(res => {
        if (!res.ok) {
            return res.text().then(text => { throw new Error(text); });
        }
        return res.json();
    })
    .then(data => {

        // ✅ Store JWT token
        localStorage.setItem("token", data.token);

        // ✅ Store username
        localStorage.setItem("username", username);

        alert("Login Successful ✅");

        // Redirect to home
        window.location.href = "/";
    })
    .catch(err => {
        document.getElementById("errorMsg").innerText = err.message;
    });
}

</script>
}