<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventBooking.UI</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventBooking.UI.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- ✅ NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    🎟 Event Booking
                </a>
<a href="/MyBookings" class="btn btn-info me-2">My Bookings</a>
                <!-- Mobile Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu -->
                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- Left Menu -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>

                    <!-- Right Side -->
                    <div class="d-flex align-items-center" id="authSection">
                        <!-- Dynamic content will load here -->
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <!-- ✅ MAIN CONTENT -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- ✅ FOOTER -->
    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - <strong>EventBooking.UI</strong> |
            <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function renderAuthUI() {
            let token = localStorage.getItem("token");
            let username = localStorage.getItem("username");
            let container = document.getElementById("authSection");

            if (token) {
                // ✅ Logged in view
                container.innerHTML = `
                    <span class="text-white me-3">👤 ${username}</span>
                    <button onclick="logout()" class="btn btn-danger">
                        Logout
                    </button>
                `;
            } else {
                // ❌ Not logged in
                container.innerHTML = `
                    <a href="/Login" class="btn btn-warning me-2">Login</a>
                    <a href="/Register" class="btn btn-outline-light">Register</a>
                `;
            }
        }

        function logout() {
            localStorage.removeItem("token");
            localStorage.removeItem("username");
            window.location.href = "/Login";
        }

        // Run on page load
        renderAuthUI();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>