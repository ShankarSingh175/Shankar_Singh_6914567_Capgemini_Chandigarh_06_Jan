<h2>Transactions</h2>
<table border="1">
    <tr>
        <th>Date</th>
        <th>Type</th>
        <th>Amount</th>
    </tr>
    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Date</td>
            <td>@t.Type</td>
            <td>@t.Amount</td>
        </tr>
    }
</table>
<div style="color:red">@ViewBag.Error</div>